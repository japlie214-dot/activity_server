# Activity Server Configuration
# Copy to .env and adjust values as needed.

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_PLATFORM=          # windows | linux (auto-detected if empty)

# Turso Operational Database
TURSO_URL=                # Remote Turso URL (empty = local only)
TURSO_AUTH_TOKEN=         # Auth token for remote Turso
TURSO_LOCAL_PATH=         # Local DB path (default: data/operational.db)

# Cloud (Snowflake — real connection required, no mock)
SNOWFLAKE_ACCOUNT=       # Snowflake account identifier
SNOWFLAKE_USER=          # Snowflake username
SNOWFLAKE_PRIVATE_KEY_PATH=  # Path to .p8 private key file
SNOWFLAKE_WAREHOUSE=     # Snowflake warehouse
SNOWFLAKE_DATABASE=      # Snowflake database
SNOWFLAKE_SCHEMA=        # Snowflake schema

# Telemetry
TELEMETRY_DB_PATH=        # Telemetry DB path (default: data/telemetry.db)

# Artifacts
ARTIFACTS_DIR=            # Artifacts directory (default: data/artifacts)

# Retry
CLOUD_RETRY_ATTEMPTS=5    # Max retry attempts for cloud writes
CLOUD_RETRY_BASE_WAIT=1.0 # Base wait time (seconds) for exponential backoff

# Schema
SCHEMA_BACKUP_SUFFIX=_backup  # Suffix for backup tables during rebuild

# Long Polling
LONG_POLL_TIMEOUT=3600    # Max timeout in seconds (default: 1 hour)

# Content
CONTENT_PREVIEW_LENGTH=200  # Max chars for artifact content preview

# EDGAR (for stock tools)
EDGAR_IDENTITY=           # Email for SEC EDGAR User-Agent header
