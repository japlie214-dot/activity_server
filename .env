# Activity Server Configuration
# Copy to .env and adjust values

# ── Turso Operational Database ────────────────────────────────────────
# Local dev: leave as-is (uses ./data/operational.db)
# Production: set to your Turso remote URL
TURSO_URL=
TURSO_AUTH_TOKEN=

# ── Cloud Database (Snowflake mock) ──────────────────────────────────
CLOUD_DB_PATH=./data/cloud_snowflake.db

# ── Telemetry ────────────────────────────────────────────────────────
TELEMETRY_DB_PATH=./data/telemetry.db

# ── Artifacts ────────────────────────────────────────────────────────
ARTIFACTS_DIR=./data/artifacts

# ── Server ───────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ── Cloud Retry ──────────────────────────────────────────────────────
CLOUD_RETRY_ATTEMPTS=5
CLOUD_RETRY_BASE_WAIT=1.0
